#!/bin/sh

SWAYLOCK_MERGED_CONFIG="$XDG_CACHE_HOME/swaylock/config"

# Create a merged configuration file for swaylock.
if ! [ -e "$SWAYLOCK_MERGED_CONFIG" ]; then
    mkdir -p "$XDG_CACHE_HOME/swaylock"
    touch "$SWAYLOCK_MERGED_CONFIG"
fi

echo "# This file is automatically generated by the swaylock executable run script." > "$SWAYLOCK_MERGED_CONFIG"

# Merge configuration.
if [ -r "$XDG_CONFIG_HOME/swaylock/config" ]; then
    cat "$XDG_CONFIG_HOME/swaylock/config" >> "$XDG_CACHE_HOME/swaylock/config"
fi

# Merge pywal theme.
if [ -r "$XDG_CACHE_HOME/wal/colors-swaylock" ]; then
    cat "$XDG_CACHE_HOME/wal/colors-swaylock" >> "$XDG_CACHE_HOME/swaylock/config"
fi

# Run swaylock with the merged configuration.
exec swaylock --config "$SWAYLOCK_MERGED_CONFIG" "$@"
